  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:gme": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/build-realtime-gme.ps1",
    "generate:favicons": "python tools/generate-favicons.py",
    "build": "tsc -b && vite build",
    "verify:pwa": "node tools/verify-pwa-build.mjs",
    "build:pwa": "npm run build && npm run verify:pwa",
    "package:cloudflare": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/package-cloudflare-pages.ps1",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/silkscreen": "^5.2.8",
    "react": "^19.1.0",
